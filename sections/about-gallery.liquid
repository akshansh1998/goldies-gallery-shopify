{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'component-image-with-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .about-gallery-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .about-gallery__content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  .about-gallery__quote {
    font-style: italic;
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.75);
    margin: 4rem 0;
    border-left: 2px solid rgba(var(--color-foreground), 0.2);
    padding-left: 2rem;
    text-align: left;
  }
  .about-gallery__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    margin-top: 5rem;
  }
  @media screen and (max-width: 749px) {
    .about-gallery__grid {
      grid-template-columns: 1fr;
    }
  }
  .about-gallery__image img {
    border-radius: var(--media-radius);
    box-shadow: var(--shadow-horizontal-offset) var(--shadow-vertical-offset) var(--shadow-blur-radius) rgba(var(--color-shadow), var(--shadow-opacity));
  }
{%- endstyle -%}

<div class="about-gallery-{{ section.id }} page-width">
  <div class="about-gallery__content">
    <h1 class="h0">{{ section.settings.main_heading }}</h1>
    <div class="about-gallery__quote">
      "{{ section.settings.brand_quote }}"
    </div>
    <div class="rte">
      {{ section.settings.intro_text }}
    </div>
  </div>

  {%- for block in section.blocks -%}
    <div class="about-gallery__grid" {{ block.shopify_attributes }}>
      {%- if block.settings.layout == 'left' -%}
        <div class="about-gallery__image media media--transparent">
          {{ block.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy', sizes: '50vw', widths: '375, 750, 1100, 1500' }}
        </div>
      {%- endif -%}

      <div class="about-gallery__text">
        <h2 class="h1">{{ block.settings.heading }}</h2>
        <div class="rte">{{ block.settings.text }}</div>
      </div>

      {%- if block.settings.layout == 'right' -%}
        <div class="about-gallery__image media media--transparent">
          {{ block.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy', sizes: '50vw', widths: '375, 750, 1100, 1500' }}
        </div>
      {%- endif -%}
    </div>
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "About Gallery Layout",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "main_heading",
      "default": "Welcome to Goldie’s Gallery",
      "label": "Main Heading"
    },
    {
      "type": "text",
      "id": "brand_quote",
      "default": "Where Nature Meets Art, and Every Piece is Handmade Happiness.",
      "label": "Brand Tagline/Quote"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Intro Paragraph",
      "default": "<p>At Goldie's Gallery, we believe that the most beautiful things in the world aren't made by machines in a factory—they are grown in the earth and crafted by human hands.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Top Padding", "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Bottom Padding", "default": 60
    }
  ],
  "blocks": [
    {
      "type": "content_row",
      "name": "Content Row",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Our Mission" },
        { "type": "richtext", "id": "text", "label": "Text" },
        {
          "type": "select",
          "id": "layout",
          "options": [
            { "value": "left", "label": "Image Left" },
            { "value": "right", "label": "Image Right" }
          ],
          "default": "left",
          "label": "Desktop Image Placement"
        }
      ]
    }
  ]
}
{% endschema %}