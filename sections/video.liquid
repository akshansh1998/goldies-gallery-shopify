{{ 'video-section.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Force ratio and object-fit for the video container */
  {%- if section.settings.video_ratio != 'adapt' -%}
    .video-section__media-{{ section.id }} {
      padding-bottom: {{ section.settings.video_ratio }}% !important;
      position: relative;
    }
    .video-section__media-{{ section.id }} iframe,
    .video-section__media-{{ section.id }} video {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: 100%;
      object-fit: cover;
    }
  {%- endif -%}
{%- endstyle -%}

{%- liquid
  assign video_id = section.settings.video.id | default: section.settings.video_url.id
-%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="video-section isolate{% unless section.settings.full_width %} page-width{% endunless %} section-{{ section.id }}-padding">
    <div class="{% if section.settings.full_width %}page-width{% endif %}">
      {%- unless section.settings.heading == blank -%}
        <div class="title-wrapper title-wrapper--no-top-margin{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <h2 class="title inline-richtext {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        </div>
      {%- endunless -%}
    </div>

    {% comment %} 
      We removed the <deferred-media> wrapper and the <button> to ensure the video loads 
      immediately with the page rather than waiting for a click.
    {% endcomment %}
    <div class="video-section__media video-section__media-{{ section.id }} gradient global-media-settings{% if section.settings.full_width %} global-media-settings--full-width{% endif %} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      
      {%- if section.settings.video == null and section.settings.video_url != null -%}
        {%- liquid
          assign loop = '0'
          if section.settings.enable_video_looping
            assign loop = '1'
          endif
        -%}
        {%- if section.settings.video_url.type == 'youtube' -%}
          <iframe
            src="https://www.youtube.com/embed/{{ video_id }}?autoplay=1&mute=1&controls=0&loop={{ loop }}&playlist={{ video_id }}&enablejsapi=1"
            class="js-youtube"
            allow="autoplay; encrypted-media"
            allowfullscreen
            title="{{ section.settings.description | escape }}"
          ></iframe>
        {%- else -%}
          <iframe
            src="https://player.vimeo.com/video/{{ video_id }}?autoplay=1&muted=1&background=1&loop={{ loop }}"
            class="js-vimeo"
            allow="autoplay; encrypted-media"
            allowfullscreen
            title="{{ section.settings.description | escape }}"
          ></iframe>
        {%- endif -%}
      {%- else -%}
        {{ section.settings.video | video_tag: 
            image_size: '1100x', 
            autoplay: true, 
            loop: section.settings.enable_video_looping, 
            controls: false, 
            muted: true, 
            preload: "auto" 
        }}
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Autoplay Gallery Video",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Video",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "video_ratio",
      "label": "Video aspect ratio",
      "options": [
        { "value": "56.25", "label": "16:9 (Standard)" },
        { "value": "42.85", "label": "21:9 (Cinematic)" },
        { "value": "75", "label": "4:3 (Traditional)" },
        { "value": "100", "label": "1:1 (Square)" }
      ],
      "default": "56.25"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Make section full width",
      "default": false
    },
    {
      "type": "video",
      "id": "video",
      "label": "Shopify Hosted Video (Best for Autoplay)"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["youtube", "vimeo"],
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
      "label": "URL (YouTube/Vimeo)"
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "label": "Loop video",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [{ "name": "Gallery Autoplay Video" }]
}
{% endschema %}