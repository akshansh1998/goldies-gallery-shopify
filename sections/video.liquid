{{ 'video-section.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  {%- if section.settings.video_ratio != 'adapt' -%}
    .video-section__media-{{ section.id }} {
      padding-bottom: {{ section.settings.video_ratio }}% !important;
      position: relative;
    }
    .video-section__media-{{ section.id }} iframe,
    .video-section__media-{{ section.id }} video,
    .video-section__media-{{ section.id }} img {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: 100%;
      object-fit: cover;
    }
  {%- endif -%}

  .delayed-video-{{ section.id }} {
    opacity: 0;
    transition: opacity 1s ease-in-out;
  }
  .delayed-video-{{ section.id }}.is-playing {
    opacity: 1;
  }
{%- endstyle -%}

{%- liquid
  assign video_id = section.settings.video.id | default: section.settings.video_url.id
  assign poster = section.settings.video.preview_image | default: section.settings.cover_image
  assign alt = 'sections.video.load_video' | t: description: section.settings.description | escape
-%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="video-section isolate{% unless section.settings.full_width %} page-width{% endunless %} section-{{ section.id }}-padding">
    <div class="{% if section.settings.full_width %}page-width{% endif %}">
      {%- unless section.settings.heading == blank -%}
        <div class="title-wrapper title-wrapper--no-top-margin{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <h2 class="title inline-richtext {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        </div>
      {%- endunless -%}
    </div>

    {%- if section.settings.enable_autoplay -%}
      {% comment %} Autoplay Path {% endcomment %}
      <div id="DelayedVideoContainer-{{ section.id }}" class="video-section__media video-section__media-{{ section.id }} gradient global-media-settings{% if section.settings.full_width %} global-media-settings--full-width{% endif %} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {%- if poster != null -%}
           {{ poster | image_url: width: 3840 | image_tag: class: 'delayed-poster', sizes: '100vw', widths: '375, 750, 1100, 1500, 2000, 3000, 3840' }}
        {%- endif -%}
        <div id="VideoTarget-{{ section.id }}" class="delayed-video-{{ section.id }}"></div>
      </div>

      <script>
        document.addEventListener('DOMContentLoaded', function() {
          const videoTarget = document.getElementById('VideoTarget-{{ section.id }}');
          setTimeout(() => {
            {%- if section.settings.video == null and section.settings.video_url != null -%}
              {%- if section.settings.video_url.type == 'youtube' -%}
                videoTarget.innerHTML = `<iframe src="https://www.youtube.com/embed/{{ video_id }}?autoplay=1&mute=1&controls=0&loop=1&playlist={{ video_id }}&enablejsapi=1" class="js-youtube" allow="autoplay; encrypted-media" allowfullscreen></iframe>`;
              {%- else -%}
                videoTarget.innerHTML = `<iframe src="https://player.vimeo.com/video/{{ video_id }}?autoplay=1&muted=1&background=1&loop=1" class="js-vimeo" allow="autoplay; encrypted-media" allowfullscreen></iframe>`;
              {%- endif -%}
            {%- elsif section.settings.video != null -%}
              {%- capture video_tag -%}{{ section.settings.video | video_tag: autoplay: true, loop: true, controls: false, muted: true }}{%- endcapture -%}
              videoTarget.innerHTML = `{{ video_tag | replace: '"', '\"' | strip_newlines }}`;
            {%- endif -%}
            videoTarget.classList.add('is-playing');
          }, 5000);
        });
      </script>

    {%- else -%}
      {% comment %} Standard Click-to-Play Path {% endcomment %}
      <deferred-media class="video-section__media video-section__media-{{ section.id }} deferred-media gradient global-media-settings{% if section.settings.full_width %} global-media-settings--full-width{% endif %}" data-media-id="{{ video_id }}">
        <button id="Deferred-Poster-Modal-{{ section.id }}" class="video-section__poster media deferred-media__poster" type="button">
          {%- if poster != null -%}
            {{ poster | image_url: width: 3840 | image_tag: sizes: '100vw', widths: '375, 750, 1100, 1500, 2000, 3000, 3840', alt: alt }}
          {%- else -%}
            {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
          {%- endif -%}
          <span class="deferred-media__poster-button motion-reduce">
            <span class="svg-wrapper">{{- 'icon-play.svg' | inline_asset_content -}}</span>
          </span>
        </button>
        <template>
          {%- if section.settings.video == null and section.settings.video_url != null -%}
            {%- if section.settings.video_url.type == 'youtube' -%}
              <iframe src="https://www.youtube.com/embed/{{ video_id }}?enablejsapi=1&autoplay=1" class="js-youtube" allow="autoplay; encrypted-media" allowfullscreen></iframe>
            {%- else -%}
              <iframe src="https://player.vimeo.com/video/{{ video_id }}?autoplay=1" class="js-vimeo" allow="autoplay; encrypted-media" allowfullscreen></iframe>
            {%- endif -%}
          {%- else -%}
            {{ section.settings.video | video_tag: autoplay: true, controls: true, muted: false }}
          {%- endif -%}
        </template>
      </deferred-media>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Gallery Video",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Video",
      "label": "Heading"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable Delayed Autoplay (5s)",
      "default": false,
      "info": "If enabled, video will play automatically (muted) after 5 seconds."
    },
    {
      "type": "select",
      "id": "video_ratio",
      "label": "Video aspect ratio",
      "options": [
        { "value": "56.25", "label": "16:9" },
        { "value": "42.85", "label": "21:9" },
        { "value": "100", "label": "1:1" }
      ],
      "default": "56.25"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Make section full width",
      "default": false
    },
    {
      "type": "video",
      "id": "video",
      "label": "Shopify Hosted Video"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["youtube", "vimeo"],
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
      "label": "URL (YouTube/Vimeo)"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Cover image"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Top padding", "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Bottom padding", "default": 36
    }
  ],
  "presets": [{ "name": "Goldie's Video Gallery" }]
}
{% endschema %}